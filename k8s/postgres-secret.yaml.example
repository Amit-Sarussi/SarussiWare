# Copy to postgres-secret.yaml and set real values. Do not commit postgres-secret.yaml.
#   cp k8s/postgres-secret.yaml.example k8s/postgres-secret.yaml
apiVersion: v1
kind: Secret
metadata:
  name: db-credentials
  namespace: sarussiware
stringData:
  POSTGRES_USER: app
  POSTGRES_PASSWORD: change-me
  POSTGRES_DB: appdb
  DATABASE_URL: "postgres://app:change-me@db:5432/appdb"
  JWT_SECRET: secret
